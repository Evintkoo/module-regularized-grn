flowchart LR
    subgraph TF_PATH[" TF Pathway "]
        direction TB
        TFE["TF Embedding\ne in R^512"] --> TFC["Concat\nh0 in R^523"]
        TFX["TF Expression\nx in R^11"] --> TFC
        TFC --> TF1["FC 523->2048\nBN + ReLU\nDropout 0.2"]
        TF1 --> TF2["FC 2048->1024\nBN + ReLU\nDropout 0.2"]
        TF2 --> TF3["FC 1024->512\nLinear"]
        TF3 --> ZTF["z_TF in R^512"]
    end

    subgraph GENE_PATH[" Gene Pathway "]
        direction TB
        GE["Gene Embedding\ne in R^512"] --> GC["Concat\nh0 in R^523"]
        GX["Gene Expression\nx in R^11"] --> GC
        GC --> G1["FC 523->2048\nBN + ReLU\nDropout 0.2"]
        G1 --> G2["FC 2048->1024\nBN + ReLU\nDropout 0.2"]
        G2 --> G3["FC 1024->512\nLinear"]
        G3 --> ZG["z_Gene in R^512"]
    end

    subgraph SCORING[" Scoring "]
        direction TB
        SIM["Dot Product Similarity\nz_TF . z_Gene / tau\ntau = 0.05"]
        SIG["Sigmoid -> P(edge)\nthreshold = 0.5"]
        SIM --> SIG
    end

    subgraph TRAINING[" Training "]
        direction TB
        LOSS["BCE + L2 reg\nlambda = 0.01"]
        ADAM["Adam lr=5e-3\nbatch=256 ep<=60"]
        LOSS --> ADAM
    end

    ZTF --> SIM
    ZG --> SIM
    SIG --> LOSS

